{
  "name": "mogu-mogu-panic",
  "version": "1.0.0",
  "private": true,
  "description": "MOGU MOGU PANIC - ハイパーカジュアルゲーム(Web + iOS/Capacitor)",
  "scripts": {
    "build:web": "node scripts/build-web.js",
    "sync": "npm run build:web && cap sync",
    "sync:ios": "npm run build:web && cap sync ios",
    "open:ios": "cap open ios",
    "icons": "capacitor-assets generate --ios --iconBackgroundColor #7ec8e3 --iconBackgroundColorDark #16323d"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/preferences": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1"
  }
}
